APP_NAME=BME Async SAM3 Backend
DEBUG=false
API_V1_PREFIX=/api

MYSQL_URL=mysql+asyncmy://root:password@127.0.0.1:3306/bme
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_QUEUE=sam3_analysis
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_POOL=solo
CELERY_TASK_SOFT_TIME_LIMIT=120
CELERY_TASK_TIME_LIMIT=180
CELERY_RESULT_EXPIRES=3600

UPLOAD_DIR=Backend/uploads
MODEL_LOAD_MODE=mock
MODEL_DEVICE=cuda
MODEL_CHECKPOINT_PATH=MedicalSAM3/checkpoint/MedSAM3.pt
MAX_UPLOAD_SIZE_MB=20
AUTH_HEADER_NAME=X-User-Id
